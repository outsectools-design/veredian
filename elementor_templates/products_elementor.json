              "elType": "widget",
              "settings": {
                "html": "\n\n<nav class=\"nav\" role=\"navigation\">\n  <div class=\"nav__inner\">\n    <a href=\"index.html\" class=\"nav__logo\"><img src=\"03_compact_dark.svg\" alt=\"Veredian\" height=\"40\"></a>\n    <div class=\"nav__links\">\n      <a href=\"products.html\" class=\"active text-teal\">Products</a><a href=\"technology.html\">Technology</a><a href=\"markets.html\">Markets</a><a href=\"company.html\">Company</a><a href=\"investors.html\">Investors</a><a href=\"news.html\">News</a><a href=\"careers.html\">Careers</a><a href=\"contact.html\">Contact</a>\n    </div>\n    <div class=\"nav__actions\">\n      <button class=\"nav__lang\">EN | AR</button>\n      <a href=\"deck-request.html\" class=\"btn btn--primary\">REQUEST BRIEFING</a>\n    </div>\n  </div>\n</nav>\n\n<section class=\"hero hero--short\">\n  <div class=\"container hero__inner hero__inner--centered\">\n    <div class=\"hero__content\">\n      <p class=\"eyebrow text-teal\">THE SOVEREIGN SILICON PORTFOLIO</p>\n      <h1 class=\"text-white\">One Foundation.<br>A Family of Sovereign Silicon.</h1>\n      <p class=\"hero__subtitle\">Veredian is building a portfolio of sovereign semiconductor platforms on one nationally-ownable IP foundation. EDGE-VISION™ 1000 is the first silicon — not the last.</p>\n    </div>\n  </div>\n</section>\n\n<section class=\"section section--light\">\n  <div class=\"container\">\n    <div class=\"section__header text-center\">\n      <h2>The Product Line</h2>\n    </div>\n    <div class=\"grid grid--2\">\n      <div class=\"card card--portfolio\">\n        <div class=\"card__badge-row\">\n          <div class=\"card__badge card__badge--flagship\">FLAGSHIP · IN DEVELOPMENT</div>\n        </div>\n        <div class=\"card__icon-wrap\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z\"></path><circle cx=\"12\" cy=\"13\" r=\"4\"></circle></svg></div>\n        <h3 class=\"card__title\">EDGE-VISION™ 1000</h3>\n        <p class=\"card__subtitle\">Edge AI Vision SoC</p>\n        <p class=\"card__body\">8 TOPS AI vision inference for surveillance, transport, ports, and critical facilities. GlobalFoundries 22FDX. Ten verticals on one chip.</p>\n      </div>\n      <div class=\"card card--portfolio\">\n        <div class=\"card__badge-row\">\n          <div class=\"card__badge card__badge--neutral\">IN DEFINITION</div>\n        </div>\n        <div class=\"card__icon-wrap\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><circle cx=\"12\" cy=\"12\" r=\"6\"></circle><circle cx=\"12\" cy=\"12\" r=\"2\"></circle></svg></div>\n        <h3 class=\"card__title\">EDGE-SENSE™</h3>\n        <p class=\"card__subtitle\">Multi-Sensor Fusion SoC</p>\n        <p class=\"card__body\">Radar, LiDAR, and vision fusion at the sovereign edge — perimeter security, UAV payloads, and industrial sensing on the same IP foundation.</p>\n      </div>\n      <div class=\"card card--portfolio\">\n        <div class=\"card__badge-row\">\n          <div class=\"card__badge card__badge--neutral\">ROADMAP</div>\n        </div>\n        <div class=\"card__icon-wrap\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"3\" y=\"11\" width=\"18\" height=\"11\" rx=\"2\" ry=\"2\"></rect><path d=\"M7 11V7a5 5 0 0 1 10 0v4\"></path></svg></div>\n        <h3 class=\"card__title\">EDGE-SECURE™</h3>\n        <p class=\"card__subtitle\">Sovereign Security Silicon</p>\n        <p class=\"card__body\">Hardware root of trust, cryptographic key management, and secure element silicon — the trust anchor for national infrastructure systems.</p>\n      </div>\n      <div class=\"card card--portfolio\">\n        <div class=\"card__badge-row\">\n          <div class=\"card__badge card__badge--gold\">PROGRAMME SERVICES</div>\n        </div>\n        <div class=\"card__icon-wrap\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polygon points=\"12 2 2 7 12 12 22 7 12 2\"></polygon><polyline points=\"2 12 12 17 22 12\"></polyline><polyline points=\"2 17 12 22 22 17\"></polyline></svg></div>\n        <h3 class=\"card__title\">Sovereign Silicon Programmes</h3>\n        <p class=\"card__subtitle\">Custom National Silicon</p>\n        <p class=\"card__body\">Your requirement, your IP, your chip — custom sovereign silicon from architecture to fab, delivered by founders with 80+ combined years of semiconductor tapeout experience.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class=\"section section--navy\">\n  <div class=\"container\">\n    <div class=\"section__header text-center\">\n      <h2 class=\"text-white\">The Sovereign IP Foundation</h2>\n      <p>Every product shares the same audited, nationally-ownable IP blocks. One certification pathway carries the whole portfolio — and every custom programme.</p>\n    </div>\n    \n    <div class=\"ip-grid\">\n      <div class=\"ip-card\">\n        <div class=\"card__icon-wrap\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><line x1=\"12\" y1=\"8\" x2=\"12\" y2=\"16\"></line><line x1=\"8\" y1=\"12\" x2=\"16\" y2=\"12\"></line></svg></div>\n        <h3 class=\"ip-card__title\">Neural Processing Unit</h3>\n        <p class=\"ip-card__desc\">Scalable sovereign NPU IP — the inference engine shared across every product in the portfolio.</p>\n      </div>\n      <div class=\"ip-card\">\n        <div class=\"card__icon-wrap\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z\"></path><circle cx=\"12\" cy=\"12\" r=\"3\"></circle></svg></div>\n        <h3 class=\"ip-card__title\">Vision & Sensor Pipeline</h3>\n        <p class=\"ip-card__desc\">HDR ISP and multi-sensor front-end IP — defensibility, radar, and LiDAR fusion ready.</p>\n      </div>\n      <div class=\"ip-card\">\n        <div class=\"card__icon-wrap\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"3\" y=\"11\" width=\"18\" height=\"11\" rx=\"2\" ry=\"2\"></rect><path d=\"M7 11V7a5 5 0 0 1 10 0v4\"></path></svg></div>\n        <h3 class=\"ip-card__title\">Sovereign Security Stack</h3>\n        <p class=\"ip-card__desc\">Root of trust, secure boot, key provisioning — the same audited trust anchor in every chip.</p>\n      </div>\n      <div class=\"ip-card\">\n        <div class=\"card__icon-wrap\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"4\" y=\"4\" width=\"16\" height=\"16\" rx=\"2\" ry=\"2\"></rect><rect x=\"9\" y=\"9\" width=\"6\" height=\"6\"></rect><line x1=\"9\" y1=\"1\" x2=\"9\" y2=\"4\"></line><line x1=\"15\" y1=\"1\" x2=\"15\" y2=\"4\"></line><line x1=\"9\" y1=\"20\" x2=\"9\" y2=\"23\"></line><line x1=\"15\" y1=\"20\" x2=\"15\" y2=\"23\"></line><line x1=\"20\" y1=\"9\" x2=\"23\" y2=\"9\"></line><line x1=\"20\" y1=\"14\" x2=\"23\" y2=\"14\"></line><line x1=\"1\" y1=\"9\" x2=\"4\" y2=\"9\"></line><line x1=\"1\" y1=\"14\" x2=\"4\" y2=\"14\"></line></svg></div>\n        <h3 class=\"ip-card__title\">CPU Chassis & I/O</h3>\n        <p class=\"ip-card__desc\">CPU subsystem, memory architecture, and interface IP — the proven backbone of the platform.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class=\"section section--white\">\n  <div class=\"container\" style=\"max-width: 900px;\">\n    <p class=\"eyebrow text-teal\">FLAGSHIP · IN DEVELOPMENT</p>\n    <h2>EDGE-VISION™ 1000 — Technical Specification</h2>\n    <p style=\"margin-bottom: 32px;\">The first product of the portfolio. Every specification is derived from sovereign deployment workloads — the chip is sized exactly for the mission.</p>\n    \n    <div class=\"table-wrapper\">\n      <table class=\"table--spec\">\n        <tbody>\n          <tr>\n            <td>Process Node</td>\n            <td>GlobalFoundries 22FDX FD-SOI — sovereign manufacturing alignment, body-bias power efficiency</td>\n          </tr>\n          <tr>\n            <td>AI Engine</td>\n            <td>8 TOPS INT8 — simultaneous multi-stream inference across concurrent workloads</td>\n          </tr>\n          <tr>\n            <td>Vision Processing</td>\n            <td>HDR + low-light ISP · 4K capable · Up to 8× 1080p concurrent video streams</td>\n          </tr>\n          <tr>\n            <td>Power Envelope</td>\n            <td>< 5W active · FD-SOI body-bias dynamic power management · UAV/embedded fit</td>\n          </tr>\n          <tr>\n            <td>Sovereign Security</td>\n            <td>Hardware root of trust · Secure boot · Cryptographic key provisioning · Hardware isolation</td>\n          </tr>\n          <tr>\n            <td>Lifecycle</td>\n            <td>15+ year industrial grade support commitment</td>\n          </tr>\n          <tr>\n            <td>Compliance</td>\n            <td>Designed and built for annual national CIP recertification frameworks globally</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n  </div>\n</section>\n\n<section class=\"section section--navy text-center\">\n  <div class=\"container\">\n    <h2 class=\"text-white\" style=\"margin-bottom: 16px;\">Have a National Silicon Requirement?</h2>\n    <p class=\"text-silver\" style=\"margin-bottom: 40px; max-width:600px; margin-left:auto; margin-right:auto;\">Sovereign Silicon Programmes deliver custom national silicon — your requirement, your IP, your chip — from architecture to fab.</p>\n    <a href=\"contact.html\" class=\"btn btn--primary\">DISCUSS A PROGRAMME</a>\n  </div>\n</section>\n\n<footer class=\"footer\">\n  <div class=\"container\">\n    <div class=\"footer__grid\">\n      <div class=\"footer__brand\">\n        <img src=\"03_compact_dark.svg\" alt=\"Veredian\" height=\"36\">\n        <p class=\"footer__tagline\" style=\"margin-top:24px;color:#A8B4C0;font-size:12px;\">Sovereign Silicon. Designed for Nations.<br>© 2026 Veredian. All rights reserved.</p>\n      </div>\n      <div class=\"footer__nav\">\n        <p class=\"footer__links-title\">PAGES</p>\n        <div class=\"footer__links\">\n          <a href=\"products.html\">Products</a>\n          <a href=\"technology.html\">Technology</a>\n          <a href=\"markets.html\">Markets</a>\n          <a href=\"company.html\">Company</a>\n        </div>\n      </div>\n      <div class=\"footer__nav\">\n        <p class=\"footer__links-title\">COMPANY</p>\n        <div class=\"footer__links\">\n          <a href=\"investors.html\">Investors</a>\n          <a href=\"news.html\">News</a>\n          <a href=\"careers.html\">Careers</a>\n          <a href=\"contact.html\">Contact</a>\n        </div>\n      </div>\n      <div class=\"footer__offices\">\n        <p class=\"footer__offices-title\">CONTACT</p>\n        <div class=\"footer__office\">\n          <p class=\"footer__office-label\" style=\"color:var(--silver);\">Middle East HQ<br>Engineering Centre</p>\n          <a href=\"mailto:hello@veredian.ai\" class=\"text-teal\" style=\"display:block;margin-top:8px;\">hello@veredian.ai</a>\n        </div>\n      </div>\n    </div>\n    <div class=\"footer__legal\" style=\"text-align:center;font-size:10px;color:rgba(255,255,255,0.2);margin-top:80px;\">\n      <p>This website is provided for informational purposes only and does not constitute an offer or solicitation of any securities in any jurisdiction. Qualified investors and programme partners only.</p>\n    </div>\n  </div>\n</footer>\n"
              },
