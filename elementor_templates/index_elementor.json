              "id": "maoxilv",
              "elType": "widget",
              "settings": {
                "html": "\n\n<nav class=\"nav\" role=\"navigation\">\n  <div class=\"nav__inner\">\n    <a href=\"index.html\" class=\"nav__logo\"><img src=\"03_compact_dark.svg\" alt=\"Veredian\" height=\"40\"></a>\n    <div class=\"nav__links\">\n      <a href=\"products.html\">Products</a><a href=\"technology.html\">Technology</a><a href=\"markets.html\">Markets</a><a href=\"company.html\">Company</a><a href=\"investors.html\">Investors</a><a href=\"news.html\">News</a><a href=\"careers.html\">Careers</a><a href=\"contact.html\">Contact</a>\n    </div>\n    <div class=\"nav__actions\">\n      <button class=\"nav__lang\">EN | AR</button>\n      <a href=\"deck-request.html\" class=\"btn btn--primary\">REQUEST BRIEFING</a>\n    </div>\n  </div>\n</nav>\n\n<section class=\"hero\">\n  <div class=\"hero__background\"></div>\n  <div class=\"container hero__inner\">\n    <div class=\"hero__content\">\n      <p class=\"eyebrow text-teal\">SOVEREIGN SEMICONDUCTOR COMPANY · SERIES A 2026</p>\n      <h1>Sovereign Silicon.<br>Designed for<br>Nations.</h1>\n      <p class=\"hero__subtitle\">Veredian designs sovereign semiconductor platforms — AI vision, secure sensing, and trusted silicon that nations own, audit, and control. First silicon: EDGE-VISION™ 1000.</p>\n      <div class=\"hero__ctas\">\n        <a href=\"deck-request.html\" class=\"btn btn--primary\">REQUEST THE BRIEFING</a>\n        <a href=\"products.html\" class=\"btn btn--ghost text-white\">EXPLORE THE PORTFOLIO</a>\n      </div>\n    </div>\n    <div class=\"hero__visual\">\n      <div class=\"portfolio-diagram\">\n        <div class=\"portfolio-diagram__header\">ONE FOUNDATION - MANY SOVEREIGN PRODUCTS</div>\n        <div class=\"portfolio-diagram__tree\"></div>\n        <div class=\"portfolio-diagram__chips\">\n          <div class=\"diagram-chip diagram-chip--flagship\">\n            <div class=\"diagram-chip__title\">EDGE-VISION™</div>\n            <div class=\"diagram-chip__sub\">10 Verticals SoC</div>\n            <div class=\"diagram-chip__badge\">FLAGSHIP · IN DEVELOPMENT</div>\n          </div>\n          <div class=\"diagram-chip diagram-chip--future\">\n            <div class=\"diagram-chip__title\">EDGE-SENSE™</div>\n            <div class=\"diagram-chip__sub\">Sensor Fusion SoC</div>\n            <div class=\"diagram-chip__badge\">IN DEFINITION</div>\n          </div>\n          <div class=\"diagram-chip diagram-chip--future\">\n            <div class=\"diagram-chip__title\">EDGE-SECURE™</div>\n            <div class=\"diagram-chip__sub\">Security Silicon</div>\n            <div class=\"diagram-chip__badge\">ROADMAP</div>\n          </div>\n        </div>\n        <div class=\"portfolio-diagram__foundation\">\n          <div class=\"foundation-title\">SOVEREIGN IP FOUNDATION</div>\n          <div class=\"foundation-sub\">NPU - ISP - Security Stack - CPU Chassis</div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class=\"section section--navy\">\n  <div class=\"container\">\n    <div class=\"stat-bar\">\n      <div class=\"stat-bar__grid\">\n        <div class=\"stat-bar__item\">\n          <div class=\"stat-bar__number\">4</div>\n          <div class=\"stat-bar__label\">SILICON PLATFORMS</div>\n        </div>\n        <div class=\"stat-bar__item\">\n          <div class=\"stat-bar__number\">10</div>\n          <div class=\"stat-bar__label\">MISSION VERTICALS</div>\n        </div>\n        <div class=\"stat-bar__item\">\n          <div class=\"stat-bar__number\">15+ Yrs</div>\n          <div class=\"stat-bar__label\">LIFECYCLE COMMITMENT</div>\n        </div>\n        <div class=\"stat-bar__item\">\n          <div class=\"stat-bar__number\">80+</div>\n          <div class=\"stat-bar__label\">COMBINED YRS SILICON EXP.</div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class=\"section section--white\">\n  <div class=\"container\">\n    <div class=\"section__header text-center\">\n      <p class=\"eyebrow text-teal\">THE CHALLENGE</p>\n      <h2>Why Commercial Silicon Cannot Serve<br>Sovereign Infrastructure</h2>\n    </div>\n    <div class=\"grid grid--3\">\n      <div class=\"card card--challenge\">\n        <div class=\"card__icon-wrap\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"></path></svg></div>\n        <h3 class=\"card__title\">Export-Control Risk</h3>\n        <p class=\"card__body\">Foreign governments can restrict or revoke access to commercial silicon at any time — mid-programme, mid-deployment, mid-crisis.</p>\n      </div>\n      <div class=\"card card--challenge\">\n        <div class=\"card__icon-wrap\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z\"></path><circle cx=\"12\" cy=\"12\" r=\"3\"></circle></svg></div>\n        <h3 class=\"card__title\">No Architecture Visibility</h3>\n        <p class=\"card__body\">Closed firmware prevents the security audits mandated for critical infrastructure. You cannot certify what you cannot inspect.</p>\n      </div>\n      <div class=\"card card--challenge\">\n        <div class=\"card__icon-wrap\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><polyline points=\"12 6 12 12 16 14\"></polyline></svg></div>\n        <h3 class=\"card__title\">Lifecycle Mismatch</h3>\n        <p class=\"card__body\">Consumer chips are discontinued in 3-5 years. National infrastructure is planned and budgeted in decades.</p>\n      </div>\n      <div class=\"card card--challenge\">\n        <div class=\"card__icon-wrap\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><line x1=\"2\" y1=\"12\" x2=\"22\" y2=\"12\"></line><path d=\"M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z\"></path></svg></div>\n        <h3 class=\"card__title\">No Data Sovereignty</h3>\n        <p class=\"card__body\">Cloud-dependent inference violates national data residency law. Data must be processed on-device, on-shore.</p>\n      </div>\n      <div class=\"card card--challenge\">\n        <div class=\"card__icon-wrap\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"3\" y=\"11\" width=\"18\" height=\"11\" rx=\"2\" ry=\"2\"></rect><path d=\"M7 11V7a5 5 0 0 1 10 0v4\"></path></svg></div>\n        <h3 class=\"card__title\">No Sovereign Security Stack</h3>\n        <p class=\"card__body\">No hardware root of trust, no key provisioning, no secure boot in foreign commercial SoCs at this price point.</p>\n      </div>\n      <div class=\"card card--challenge\">\n        <div class=\"card__icon-wrap\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polygon points=\"13 2 3 14 12 14 11 22 21 10 12 10 13 2\"></polygon></svg></div>\n        <h3 class=\"card__title\">Supply-Chain Fragility</h3>\n        <p class=\"card__body\">Single-supplier dependency creates unacceptable risk. When the vendor discontinues, the programme fails.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class=\"section section--light\">\n  <div class=\"container\">\n    <div class=\"section__header text-center\">\n      <p class=\"eyebrow text-teal\">THE PORTFOLIO</p>\n      <h2>One IP Foundation. A Family of Sovereign Silicon.</h2>\n      <p>Every Veredian product is built on the same nationally-ownable IP foundation — NPU, ISP, sovereign security stack, and CPU chassis. One audit. One certification pathway. Many products.</p>\n    </div>\n    <div class=\"grid grid--2\">\n      <div class=\"card card--portfolio\">\n        <div class=\"card__badge-row\">\n          <div class=\"card__badge card__badge--flagship\">FLAGSHIP · IN DEVELOPMENT</div>\n        </div>\n        <div class=\"card__icon-wrap\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z\"></path><circle cx=\"12\" cy=\"13\" r=\"4\"></circle></svg></div>\n        <h3 class=\"card__title\">EDGE-VISION™ 1000</h3>\n        <p class=\"card__subtitle\">Edge AI Vision SoC</p>\n        <p class=\"card__body\">8 TOPS AI vision inference for surveillance, transport, ports, and critical facilities. GlobalFoundries 22FDX. Ten verticals on one chip.</p>\n      </div>\n      <div class=\"card card--portfolio\">\n        <div class=\"card__badge-row\">\n          <div class=\"card__badge card__badge--neutral\">IN DEFINITION</div>\n        </div>\n        <div class=\"card__icon-wrap\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><circle cx=\"12\" cy=\"12\" r=\"6\"></circle><circle cx=\"12\" cy=\"12\" r=\"2\"></circle></svg></div>\n        <h3 class=\"card__title\">EDGE-SENSE™</h3>\n        <p class=\"card__subtitle\">Multi-Sensor Fusion SoC</p>\n        <p class=\"card__body\">Radar, LiDAR, and vision fusion at the sovereign edge — perimeter security, UAV payloads, and industrial sensing on the same IP foundation.</p>\n      </div>\n      <div class=\"card card--portfolio\">\n        <div class=\"card__badge-row\">\n          <div class=\"card__badge card__badge--neutral\">ROADMAP</div>\n        </div>\n        <div class=\"card__icon-wrap\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"3\" y=\"11\" width=\"18\" height=\"11\" rx=\"2\" ry=\"2\"></rect><path d=\"M7 11V7a5 5 0 0 1 10 0v4\"></path></svg></div>\n        <h3 class=\"card__title\">EDGE-SECURE™</h3>\n        <p class=\"card__subtitle\">Sovereign Security Silicon</p>\n        <p class=\"card__body\">Hardware root of trust, cryptographic key management, and secure element silicon — the trust anchor for national infrastructure systems.</p>\n      </div>\n      <div class=\"card card--portfolio\">\n        <div class=\"card__badge-row\">\n          <div class=\"card__badge card__badge--gold\">PROGRAMME SERVICES</div>\n        </div>\n        <div class=\"card__icon-wrap\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polygon points=\"12 2 2 7 12 12 22 7 12 2\"></polygon><polyline points=\"2 12 12 17 22 12\"></polyline><polyline points=\"2 17 12 22 22 17\"></polyline></svg></div>\n        <h3 class=\"card__title\">Sovereign Silicon Programmes</h3>\n        <p class=\"card__subtitle\">Custom National Silicon</p>\n        <p class=\"card__body\">Your requirement, your IP, your chip — custom sovereign silicon from architecture to fab, delivered by founders with 80+ combined years of semiconductor tapeout experience.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class=\"section section--navy\">\n  <div class=\"container\">\n    <div class=\"section__header text-center\">\n      <p class=\"eyebrow text-teal\">FLAGSHIP PROGRAMME</p>\n      <h2 class=\"text-white\">EDGE-VISION™ 1000 — First Silicon, Ten Verticals</h2>\n      <p>The flagship of the portfolio: an 8 TOPS edge AI vision SoC purpose-designed for sovereign deployment<br>— the same chip serving surveillance, oil & gas, ports, transport, defence, UAVs, industrial, robotics,<br>smart mobility, and healthcare.</p>\n    </div>\n    \n    <div class=\"platform-compare\">\n      <div class=\"compare-box compare-box--narrow\">\n        <p class=\"compare-title\">Narrow approach — one chip, one use case</p>\n        <p>Each new vertical requires new silicon. One procurement cycle.<br>No platform value.</p>\n      </div>\n      <div class=\"compare-box compare-box--platform\">\n        <p class=\"compare-title text-teal\">Veredian platform approach ✓</p>\n        <p>Same silicon, same firmware stack, same lifecycle across all ten<br>verticals — and the same IP foundation carries every future<br>product in the portfolio.</p>\n      </div>\n    </div>\n    \n    <div class=\"text-center\" style=\"margin-top: 48px;\">\n      <a href=\"products.html\" class=\"btn btn--ghost\">EXPLORE EDGE-VISION™ 1000 &rarr;</a>\n    </div>\n  </div>\n</section>\n\n<section class=\"section team-section\">\n  <div class=\"container\">\n    <div class=\"section__header text-center\">\n      <h2>Silicon Veterans. Global Builders.</h2>\n      <p>Led by semiconductor leaders with 80+ combined years of frontier silicon delivery — joined by co-founders across<br>AI, data science, and international growth.</p>\n    </div>\n    <div class=\"team-grid\">\n      <div class=\"team-card\">\n        <div class=\"team-card__initials\">RK</div>\n        <div class=\"team-card__name\">Ravi Koodli</div>\n        <div class=\"team-card__role\">CEO & Lead Founder</div>\n      </div>\n      <div class=\"team-card\">\n        <div class=\"team-card__initials\">PK</div>\n        <div class=\"team-card__name\">Prasanna K.</div>\n        <div class=\"team-card__role\">Micro Architect</div>\n      </div>\n      <div class=\"team-card\">\n        <div class=\"team-card__initials\">PS</div>\n        <div class=\"team-card__name\">Prateek Sikka</div>\n        <div class=\"team-card__role\">SoC Engineering</div>\n      </div>\n      <div class=\"team-card\">\n        <div class=\"team-card__initials\">DV</div>\n        <div class=\"team-card__name\">Devan</div>\n        <div class=\"team-card__role\">Strategic Partnerships</div>\n      </div>\n      <div class=\"team-card\">\n        <div class=\"team-card__initials\">AV</div>\n        <div class=\"team-card__name\">Ananth Vandothra</div>\n        <div class=\"team-card__role\">Data Science & AI</div>\n      </div>\n      <div class=\"team-card\">\n        <div class=\"team-card__initials\">KK</div>\n        <div class=\"team-card__name\">Krishna KR</div>\n        <div class=\"team-card__role\">Software & Platforms</div>\n      </div>\n    </div>\n    \n    <div class=\"company-strip\">\n      <div class=\"company-strip__logos\">\n        <span>INTEL</span>\n        <span>QUALCOMM</span>\n        <span>STMICROELECTRONICS</span>\n        <span>INFINEON</span>\n        <span>MAXIM</span>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class=\"section section--navy text-center\" style=\"padding-top: 40px;\">\n  <div class=\"container\">\n    <h2 class=\"text-white\" style=\"margin-bottom: 16px;\">Veredian is currently raising its Series A.</h2>\n    <p class=\"text-silver\" style=\"margin-bottom: 40px;\">We welcome engagement from sovereign investors, national programme offices, and qualified institutional partners.</p>\n    <a href=\"deck-request.html\" class=\"btn btn--primary\">REQUEST THE INVESTMENT BRIEFING</a>\n  </div>\n</section>\n\n<footer class=\"footer\">\n  <div class=\"container\">\n    <div class=\"footer__grid\">\n      <div class=\"footer__brand\">\n        <img src=\"03_compact_dark.svg\" alt=\"Veredian\" height=\"36\">\n        <p class=\"footer__tagline\" style=\"margin-top:24px;color:#A8B4C0;font-size:12px;\">Sovereign Silicon. Designed for Nations.<br>© 2026 Veredian. All rights reserved.</p>\n      </div>\n      <div class=\"footer__nav\">\n        <p class=\"footer__links-title\">PAGES</p>\n        <div class=\"footer__links\">\n          <a href=\"products.html\">Products</a>\n          <a href=\"technology.html\">Technology</a>\n          <a href=\"markets.html\">Markets</a>\n          <a href=\"company.html\">Company</a>\n        </div>\n      </div>\n      <div class=\"footer__nav\">\n        <p class=\"footer__links-title\">COMPANY</p>\n        <div class=\"footer__links\">\n          <a href=\"investors.html\">Investors</a>\n          <a href=\"news.html\">News</a>\n          <a href=\"careers.html\">Careers</a>\n          <a href=\"contact.html\">Contact</a>\n        </div>\n      </div>\n      <div class=\"footer__offices\">\n        <p class=\"footer__offices-title\">CONTACT</p>\n        <div class=\"footer__office\">\n          <p class=\"footer__office-label\" style=\"color:var(--silver);\">Middle East HQ<br>Engineering Centre</p>\n          <a href=\"mailto:hello@veredian.ai\" class=\"text-teal\" style=\"display:block;margin-top:8px;\">hello@veredian.ai</a>\n        </div>\n      </div>\n    </div>\n    <div class=\"footer__legal\" style=\"text-align:center;font-size:10px;color:rgba(255,255,255,0.2);margin-top:80px;\">\n      <p>This website is provided for informational purposes only and does not constitute an offer or solicitation of any securities in any jurisdiction. Qualified investors and programme partners only.</p>\n    </div>\n  </div>\n</footer>\n"
              },
